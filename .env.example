# Public values from the Supabase project's Connect dialog.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only key used for organisation invitations and membership administration.
# Never prefix this value with NEXT_PUBLIC_ and never expose it to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical application URL used in authentication email redirects.
# Local example: http://localhost:3000
NEXT_PUBLIC_APP_URL=
